[
  {
    "id": "med-001-burn-treatment",
    "titre": {
      "en": "Burn Treatment",
      "fr": "Traitement des Brûlures",
      "es": "Tratamiento de Quemaduras",
      "de": "Verbrennungsbehandlung",
      "zh": "烫伤治疗"
    },
    "icone": "Flame",
    "description": {
      "en": "Emergency protocol for thermal injuries.",
      "fr": "Protocole d'urgence pour les lésions thermiques.",
      "es": "Protocolo de emergencia para lesiones térmicas.",
      "de": "Notfallprotokoll für thermische Verletzungen.",
      "zh": "热损伤紧急处理协议。"
    },
    "contenu_detaille": {
      "en": [
        "Isolate the animal in a sterile environment (paper towel substrate).",
        "Apply silver sulfadiazine cream (Flamazine) twice daily.",
        "Maintain optimal hygiene to prevent secondary infections.",
        "Consult a reptile-specialized veterinarian if blisters appear."
      ],
      "fr": [
        "Isoler l'animal en milieu stérile (sopalin).",
        "Appliquer une crème à base de sulfadiazine d'argent (Flamazine) 2x/jour.",
        "Maintenir une hygiène irréprochable pour éviter les infections secondaires.",
        "Consulter un vétérinaire spécialisé si des cloques apparaissent."
      ],
      "es": [
        "Aislar al animal en un entorno estéril.",
        "Aplicar crema de sulfadiazina de plata dos veces al día.",
        "Mantener higiene óptima.",
        "Consultar veterinario si aparecen ampollas."
      ],
      "de": [
        "Tier steril isolieren.",
        "Silbersulfadiazin-Creme zweimal täglich auftragen.",
        "Hygiene einhalten.",
        "Fachtierarzt bei Blasenbildung aufsuchen."
      ],
      "zh": [
        "将动物隔离在无菌环境中。",
        "每天两次涂抹磺胺嘧啶银乳膏。",
        "保持卫生以预防继发感染。",
        "如果出现水泡，请咨询兽医。"
      ]
    },
    "metadata": {
      "last_updated": "2026-04-13T15:00:00Z",
      "version": "2.0.0"
    }
  },
  {
    "id": "med-002-ri-protocol",
    "titre": {
      "en": "Respiratory Infection (RI)",
      "fr": "Infection Respiratoire (IR)",
      "es": "Infección Respiratoria",
      "de": "Atemwegsinfektion",
      "zh": "呼吸道感染"
    },
    "icone": "Wind",
    "description": {
      "en": "Detection and management of RI symptoms.",
      "fr": "Détection et gestion des symptômes d'IR.",
      "es": "Detección y manejo de síntomas de IR.",
      "de": "Erkennung und Management von Atemwegsinfektionen.",
      "zh": "呼吸道感染症状的检测与管理。"
    },
    "contenu_detaille": {
      "en": [
        "Increase ambient temperature by 2-3°C.",
        "Check for mouth gaping, mucus, or wheezing sounds.",
        "Nebulize with sterile saline or diluted F10SC if prescribed.",
        "Antibiotic treatment (Ceftazidime/Enrofloxacin) requires vet prescription."
      ],
      "fr": [
        "Augmenter la température ambiante de 2-3°C.",
        "Surveiller les bavements, sifflements ou gueule ouverte.",
        "Nébulisation avec sérum physiologique ou F10SC dilué si prescrit.",
        "Traitement antibiotique (Ceftazidime/Enrofloxacin) sur avis vétérinaire."
      ],
      "es": [
        "Aumentar temperatura 2-3°C.",
        "Observar moco o silbidos.",
        "Nebulizar con suero fisiológico.",
        "Requiere prescripción para antibióticos."
      ],
      "de": [
        "Temperatur um 2-3°C erhöhen.",
        "Auf Schleim oder Pfeifen achten.",
        "Vernebelung mit Kochsalzlösung.",
        "Antibiotika nur nach tierärztlicher Verordnung."
      ],
      "zh": [
        "将温度提高2-3°C。",
        "检查是否有粘液或喘鸣声。",
        "使用无菌生理盐水进行雾化。",
        "抗生素治疗需要兽医处方。"
      ]
    },
    "metadata": {
      "last_updated": "2026-04-13T15:00:00Z",
      "version": "2.0.0"
    }
